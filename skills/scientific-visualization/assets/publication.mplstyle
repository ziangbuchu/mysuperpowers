font.family: sans-serif
font.sans-serif: Arial, Helvetica, DejaVu Sans
font.size: 8
axes.labelsize: 9
axes.titlesize: 9
axes.linewidth: 0.6
axes.spines.top: False
axes.spines.right: False
xtick.labelsize: 7
ytick.labelsize: 7
xtick.direction: out
ytick.direction: out
legend.frameon: False
legend.fontsize: 7
lines.linewidth: 1.6
lines.markersize: 4
savefig.dpi: 300
savefig.bbox: tight
image.cmap: viridis
